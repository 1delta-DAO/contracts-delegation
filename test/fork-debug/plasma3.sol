pragma solidity ^0.8.19;

import {IERC20All} from "test/shared/interfaces/IERC20All.sol";
import {BaseTest} from "test/shared/BaseTest.sol";
import {Chains, Tokens, Lenders} from "test/data/LenderRegistry.sol";
import "contracts/utils/CalldataLib.sol";
import {console} from "forge-std/console.sol";
import {ComposerPlugin, IComposerLike} from "plugins/ComposerPlugin.sol";

import "contracts/external-protocols/misc/FeeOnTransferDetector.sol";
import "./FOT.sol";

// solhint-disable max-line-length

interface IA {
    function upgradeAndCall(address proxy, address implementation, bytes memory data) external;
}

contract ForkTestMainnet is BaseTest {
    IComposerLike oneDV2;

    address admin = 0xBb7EAaAF2C7208384F6297C2b73935D257698c78;
    address owner = 0x999999833d965c275A2C102a4Ebf222ca938546f;
    address proxy = 0x8E24CfC19c6C00c524353CB8816f5f1c2F33c201;

    // user EOA (deposit step uses this — composer pulls sUSDAI from here)
    address mockSender = 0x00000F095Bee93CECE622Fb8FdB90B2D2F4Cc6ff;
    // user's smart-account / sub-account that ends up owning the Fluid NFT after
    // mint (matches the `from` in the captured borrow + close safeTransferFrom
    // calldata; LogOperate's last arg shows the NFT moves to this address).
    address userSubAccount = 0x2b02769c9939553312795D7693d02857456Cc498;

    // ---- Fluid Plasma T1 leverage-close scenario tokens ----
    // Collateral: sUSDAI
    address sUSDAI = 0x0B2b2B2076d95dda7817e785989fE353fe955ef9;
    // Debt: USDT0
    address USDT0 = 0xB8CE59FC3717ada4C02eaDF9682A9e934F625ebb;
    // Fluid VaultT1 (target of borrow + close txns; ERC721 vault NFT contract)
    address vaultT1 = 0x324c5Dc1fC42c7a4D43d92df1eBA58a54d13Bf2d;

    uint256 internal constant forkBlock = 0;

    function setUp() public virtual {
        // initialize the chain
        string memory chainName = Chains.PLASMA_MAINNET;

        _init(chainName, forkBlock, true);

        oneDV2 = ComposerPlugin.getComposer(chainName);

        vm.prank(owner);
        IA(admin).upgradeAndCall(proxy, address(oneDV2), hex"");

        labelAddresses();
    }

    function labelAddresses() internal {
        vm.label(owner, "owner");
        vm.label(admin, "admin");
        vm.label(proxy, "proxy");
        vm.label(address(oneDV2), "Composer");
        vm.label(mockSender, "MeMeMeMe");
        vm.label(userSubAccount, "UserSubAccount");
        vm.label(sUSDAI, "sUSDAI");
        vm.label(USDT0, "USDT0");
        vm.label(vaultT1, "FluidVaultT1");
    }

    /// 1) Deposit sUSDAI collateral via composer (mints Fluid position NFT 2643)
    ///    permission: ERC20 approve sUSDAI -> proxy/composer
    ///    composer call: deltaCompose with the deposit payload
    function test_fork_fluid_plasma_close_step1_deposit() external {
        // fund the user with sUSDAI for the deposit
        deal(sUSDAI, mockSender, 500 ether);

        // permission: approve composer to pull sUSDAI
        vm.prank(mockSender);
        IERC20All(sUSDAI).approve(proxy, 0x1b1ae4d6e2ef500000);

        // composer call (raw txn captured from API response)
        vm.prank(mockSender);
        (bool ok,) = proxy.call{value: 0}(getDepositData());
        require(ok, "deposit composer call failed");
    }

    /// 2) Borrow 100 USDT0 against the freshly-minted position (posId=2643).
    ///    Sent to the Fluid VaultT1 (0x324c…3Bf2d) via safeTransferFrom-style
    ///    selector 0xb88d4fde — this is how 1delta routes the borrow on Fluid.
    ///    Caller is the NFT owner (`userSubAccount`), not the EOA.
    function test_fork_fluid_plasma_close_step2_borrow() external {
        // assumes step 1 already happened in same test run; if running standalone,
        // chain via test_fork_fluid_plasma_close_full_flow instead.
        vm.prank(userSubAccount);
        (bool ok,) = vaultT1.call{value: 0}(getBorrowData());
        require(ok, "borrow call failed");
    }

    /// 3) Leverage-close: withdraw sUSDAI, swap to USDT0 via OpenOcean, repay USDT0.
    ///    Output-flash path. Same Fluid VaultT1 target with the close payload.
    ///    Caller is the NFT owner (`userSubAccount`).
    ///
    ///    NOTE: the embedded OpenOcean route is a stale quote (signed at the
    ///    capture timestamp). On a fork pinned to a different block the swap
    ///    under-delivers USDT0 vs the ~100 USDT0 debt the composer needs to
    ///    repay (revert: ERC20 transfer amount exceeds balance inside the
    ///    Fluid liquidityCallback). Pre-fund the proxy so the mechanical
    ///    composer/Fluid path can be exercised regardless of swap output.
    function test_fork_fluid_plasma_close_step3_close() external {
        // Pre-fund the OpenOcean executor so the embedded (stale) swap
        // route still delivers ~100 USDT0 to the composer. Pre-funding the
        // composer directly breaks the close payload's internal sweep
        // arithmetic and leads to a 1-wei repay (Fluid revert 0xdcab82e2).
        // The OpenOcean executor address comes from the swap calldata.
        address openOceanExecutor = 0x36a905DCD12C0201f884fAFda71e63E9547975DA;
        deal(USDT0, openOceanExecutor, 200_000_000);

        vm.prank(userSubAccount);
        (bool ok,) = vaultT1.call{value: 0}(getCloseData());
        require(ok, "close call failed");
    }

    /// Run the full flow (deposit → borrow → close) in a single test.
    function test_fork_fluid_plasma_close_full_flow() external {
        // ---- step 1: deposit ----
        deal(sUSDAI, mockSender, 500 ether);

        vm.prank(mockSender);
        IERC20All(sUSDAI).approve(proxy, 0x1b1ae4d6e2ef500000);

        vm.prank(mockSender);
        (bool okD,) = proxy.call{value: 0}(getDepositData());
        require(okD, "deposit failed");

        // ---- step 2: borrow 100 USDT0 ----
        // After deposit, the NFT (posId=2643) is owned by the user's
        // smart-account (`userSubAccount`), not the EOA. The captured borrow
        // calldata encodes `from = userSubAccount`, so msg.sender must match
        // (or be approved). Prank as that owner.
        vm.prank(userSubAccount);
        (bool okB,) = vaultT1.call{value: 0}(getBorrowData());
        require(okB, "borrow failed");

        // ---- step 3: leverage close ----
        // The embedded OpenOcean swap is a stale quote — pre-fund the
        // OpenOcean executor (the swap's caller-side balance source) so the
        // route delivers ~100 USDT0 to the composer. Funding the composer
        // directly breaks the close's internal sweep accounting and leads to
        // a 1-wei repay (Fluid revert 0xdcab82e2).
        deal(USDT0, address(0x36a905DCD12C0201f884fAFda71e63E9547975DA), 200_000_000);

        vm.prank(userSubAccount);
        (bool okC,) = vaultT1.call{value: 0}(getCloseData());
        require(okC, "close failed");
    }

    // ─────────────────────────── captured calldata ────────────────────────────

    /// composer.deltaCompose(...) — sUSDAI deposit (500 sUSDAI), mints posId=2643
    function getDepositData() internal pure returns (bytes memory d) {
        d =
            hex"";
    }

    /// VaultT1.<0xb88d4fde>(...) — borrow 100 USDT0 against posId=2643
    function getBorrowData() internal pure returns (bytes memory d) {
        d =
            hex"";
    }

    /// VaultT1.<0xb88d4fde>(...) — leverage close: withdraw sUSDAI, OpenOcean swap → USDT0, repay
    function getCloseData() internal pure returns (bytes memory d) {
        d =
            hex"";
    }
}
