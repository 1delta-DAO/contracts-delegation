    }

    // Deposit 20 sUSDe as collateral via EVC batch
    function getDataDeposit() internal pure returns (bytes memory d, address a) {
        a = address(0x8F73b65B4caAf64FBA2aF91cC5D4a2A1318E5D8C);
        d =
            hex"";
    }

