    address proxy = 0x816EBC5cb8A5651C902Cb06659907A93E574Db0B;

    address mockSender = 0x2b02769c9939553312795D7693d02857456Cc498;

    uint256 internal constant forkBlock = 0;

    function setUp() public virtual {
        string memory chainName = Chains.BNB_SMART_CHAIN_MAINNET;

        _init(chainName, forkBlock, true);

        vm.label(owner, "owner");
        vm.label(admin, "admin");
        vm.label(mockSender, "MeMeMeMe");
    }

    function test_lista_fork() external {
        console.log(block.number);
        address a;
        bytes memory data;

        vm.deal(mockSender, 50e18);
        // 1. Approve sUSDe for deposit vault
        (data, a) = getDataApproveAsset();
        deal(a, mockSender, 50000e18);
        vm.prank(mockSender);
        address(a).call(data);
        // 1. Approve sUSDe for deposit vault
        (data, a) = getDataApproveLista();
        vm.prank(mockSender);
        address(a).call(data);

        // 2. Deposit sUSDe as collateral
        (data, a) = getDataDeposit();
        vm.prank(mockSender);
        address(a).call{value: 0}(data);

        // 3. Borrow USDT
        (data, a) = getDataBorrow();
        vm.prank(mockSender);
        address(a).call{value: 0}(data);

        // 4. Debt swap USDT → USD1
        (data, a) = getDataDebtClose();
        vm.prank(mockSender);
        address(a).call{value: 0}(data);
    }

    // Approve sUSDe to deposit vault 0x1e55a40c...
    function getDataApproveLista() internal pure returns (bytes memory d, address a) {
        a = address(0x8F73b65B4caAf64FBA2aF91cC5D4a2A1318E5D8C);
